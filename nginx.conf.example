server {
    listen 80;
    server_name sgiptv.com.br;

    # Frontend do jogo
    location /fazendinha {
        alias /home/pi/fazendinha_online;
        index index.html;
        try_files $uri $uri/ /fazendinha/index.html;
    }

    # Backend API
    location /fazendinha/api {
        proxy_pass http://localhost:3000/api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Ajuste de cookies se necessário para o domínio principal
        proxy_cookie_path / /;
    }

    # Configurações para assets grandes ou cache podem ser adicionadas aqui
}
